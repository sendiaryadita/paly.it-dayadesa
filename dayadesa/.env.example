SECRET_KEY=change-this-secret-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Gunakan sqlite untuk development lokal.
DB_ENGINE=sqlite

# Jika ingin memakai PostgreSQL, ubah DB_ENGINE=postgresql
# lalu sesuaikan konfigurasi di bawah ini.
DB_NAME=dayadesa
DB_USER=postgres
DB_PASSWORD=your-postgres-password
DB_HOST=127.0.0.1
DB_PORT=5432
